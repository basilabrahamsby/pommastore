# Application
APP_NAME="Pommastore ERP"
APP_VERSION="1.0.0"
DEBUG=true
SECRET_KEY=your-super-secret-key-change-in-production-min-32-chars

# Database
DATABASE_URL=postgresql+asyncpg://pommastore:pommastore_dev_2026@localhost:5432/pommastore
DATABASE_URL_SYNC=postgresql://pommastore:pommastore_dev_2026@localhost:5432/pommastore

# Redis
